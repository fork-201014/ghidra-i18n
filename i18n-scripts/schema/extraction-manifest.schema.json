{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghidra-i18n/schema/extraction-manifest",
  "title": "ExtractionManifest",
  "description": "Output manifest from the extraction stage, consumed by the translation stage.",
  "type": "object",
  "required": ["metadata", "units"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["ghidraVersion", "extractionDate", "totalCandidates"],
      "properties": {
        "ghidraVersion": {
          "type": "string",
          "description": "Ghidra version at extraction time"
        },
        "extractionDate": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of extraction"
        },
        "totalCandidates": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of candidate strings found (before filtering)"
        },
        "aiFiltered": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of candidates filtered out by rule-based engine"
        },
        "aiConfirmed": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of candidates confirmed by AI as translatable"
        },
        "needsManualReview": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of candidates that need human review"
        }
      }
    },
    "units": {
      "type": "array",
      "description": "Array of TranslationUnit objects",
      "items": {
        "$ref": "./translation-unit.schema.json#"
      }
    }
  }
}
